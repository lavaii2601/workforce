{
  "version": 2,
  "routes": [
    {
      "src": "^/$",
      "dest": "/frontend/index.html",
      "headers": {
        "Cache-Control": "public, max-age=300, stale-while-revalidate=600"
      }
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/icons/(.*)",
      "dest": "/frontend/icons/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/manifest.webmanifest",
      "dest": "/frontend/manifest.webmanifest",
      "headers": {
        "Cache-Control": "public, max-age=300, stale-while-revalidate=600"
      }
    },
    {
      "src": "/sw.js",
      "dest": "/frontend/sw.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/system/cron/attendance-auto-checkout",
      "schedule": "*/5 * * * *"
    }
  ]
}
